# Postgres (used by docker-compose db service)
POSTGRES_USER=steam_auth
POSTGRES_PASSWORD=<generate-a-strong-password>
POSTGRES_DB=steam_auth

# Database (must match Postgres vars above)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=<run: python -c "import secrets; print(secrets.token_urlsafe(32))">
FERNET_KEY=<run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<choose-a-strong-password>

# Telegram
TELEGRAM_BOT_TOKEN=<your-bot-token>

# JWT (for frontend auth — falls back to SECRET_KEY if empty)
JWT_SECRET_KEY=<run: python -c "import secrets; print(secrets.token_urlsafe(32))">
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — comma-separated allowed origins (leave empty if frontend is same-origin via nginx)
CORS_ORIGINS=

# Bootstrap — optional token to protect POST /bootstrap/api-key
BOOTSTRAP_TOKEN=

# App
DEBUG=false
API_V1_PREFIX=/api/v1
